<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720" prefWidth="1140" styleClass="root-pane" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="netpro2320603.ClientController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="header-bar">
            <padding><Insets bottom="16" left="28" right="28" top="16" /></padding>
            <VBox spacing="2">
                <Label styleClass="header-title" text="TCPChat603JFX" />
                <Label styleClass="header-sub" text="localhost  ·  port 20603" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="botStatusLabel" styleClass="bot-badge" text="" />
            <Button fx:id="addBotsBtn" onAction="#onAddUser" styleClass="add-user-btn" text="Add User" />
        </HBox>
    </top>

    <center>
        <HBox spacing="0">

            <VBox maxWidth="210" minWidth="190" styleClass="sidebar">
                <HBox alignment="CENTER_LEFT" styleClass="sidebar-header">
                    <padding><Insets bottom="14" left="16" right="16" top="14" /></padding>
                    <Label styleClass="sidebar-title" text="Online Users" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="onlineCountLabel" styleClass="online-badge" text="0" />
                </HBox>

                <ListView fx:id="onlineUsersList" styleClass="users-list" VBox.vgrow="ALWAYS" />

                <VBox spacing="8" styleClass="bots-panel">
                    <padding><Insets bottom="14" left="14" right="14" top="14" /></padding>
                    <Label styleClass="bots-title" text="Bot Manager" />
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <ComboBox fx:id="botCountCombo" prefWidth="72" styleClass="bot-combo" />
                        <Label styleClass="bots-label" text="bot(s)" />
                    </HBox>
                    <Button maxWidth="Infinity" onAction="#onAddBots" styleClass="launch-bots-btn" text="Launch Bots" />
                </VBox>
            </VBox>

            <SplitPane fx:id="mainSplit" dividerPositions="1.0" styleClass="main-split" HBox.hgrow="ALWAYS">

                <VBox spacing="0" styleClass="chat-pane">
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="pane-header">
                        <padding><Insets bottom="12" left="16" right="16" top="12" /></padding>
                        <StackPane styleClass="avatar">
                            <Label fx:id="leftAvatarLabel" styleClass="avatar-text" text="M" />
                        </StackPane>
                        <VBox spacing="1" HBox.hgrow="ALWAYS">
                            <Label fx:id="leftUsernameField" styleClass="username-field" text="Me" />
                            <Label fx:id="leftStatusLabel" styleClass="status-label" text="Connecting..." />
                        </VBox>
                        <Button onAction="#onLeftLeave" styleClass="leave-btn" text="Leave" />
                        <Button onAction="#onLeftConnect" styleClass="reconnect-btn" text="Reconnect" />
                    </HBox>
                    <ListView fx:id="leftChatList" styleClass="chat-list" VBox.vgrow="ALWAYS" />
                    <HBox alignment="CENTER" spacing="10" styleClass="input-bar">
                        <padding><Insets bottom="12" left="16" right="16" top="12" /></padding>
                        <TextField fx:id="leftInputField" promptText="Type your message here..." styleClass="msg-input" HBox.hgrow="ALWAYS" />
                        <Button fx:id="leftSendBtn" onAction="#onLeftSend" styleClass="send-btn" text="Send" />
                    </HBox>
                </VBox>

                <VBox fx:id="rightPane" managed="false" spacing="0" styleClass="chat-pane">
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="pane-header">
                        <padding><Insets bottom="12" left="16" right="16" top="12" /></padding>
                        <StackPane styleClass="avatar">
                            <Label fx:id="rightAvatarLabel" styleClass="avatar-text" text="P" />
                        </StackPane>
                        <VBox spacing="1" HBox.hgrow="ALWAYS">
                            <Label fx:id="rightUsernameField" styleClass="username-field" text="Peer" />
                            <Label fx:id="rightStatusLabel" styleClass="status-label" text="Connecting..." />
                        </VBox>
                        <Button onAction="#onRemoveUser" styleClass="leave-btn" text="Remove" />
                        <Button onAction="#onRightConnect" styleClass="reconnect-btn" text="Reconnect" />
                    </HBox>
                    <ListView fx:id="rightChatList" styleClass="chat-list" VBox.vgrow="ALWAYS" />
                    <HBox alignment="CENTER" spacing="10" styleClass="input-bar">
                        <padding><Insets bottom="12" left="16" right="16" top="12" /></padding>
                        <TextField fx:id="rightInputField" promptText="Type your message here..." styleClass="msg-input" HBox.hgrow="ALWAYS" />
                        <Button fx:id="rightSendBtn" onAction="#onRightSend" styleClass="send-btn" text="Send" />
                    </HBox>
                </VBox>

            </SplitPane>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <padding><Insets bottom="5" left="24" right="24" top="5" /></padding>
            <Label styleClass="statusbar-text" text="Server running on localhost:20603" />
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="statusbar-text" text="TCPChat603JFX  |  Java + JavaFX  |  TCP" />
        </HBox>
    </bottom>

</BorderPane>